    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "dev": "^0.1.3",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "fishery": "^2.4.0",
    "isbot": "^5",
    "morgan": "^1.10.1",
    "node-cache": "^5.1.2",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.14.2",
    "react-router-dom": "~7.14.0",
    "recharts": "^3.8.1",
    "swagger-ui-react": "^5.32.5",
    "tailwindcss": "^4.2.4",
    "vite-express": "^0.22.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@react-router/dev": "~7.14.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/swagger-ui-react": "^5.18.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "http-server": "^14.1.1",
    "nodemon": "^3.1.10",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "~5.2.2",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  },
  "name": "naga-aip",
  "private": false,
  "scripts": {
    "build": "tsc -b && vite build && mkdir dist/src && cp src/routes/* dist/src && cp -R data dist && cp assets/* dist/assets",
    "build:client:production": "react-router build --config vite.config.ts",
    "build:server:production": "tsc --project tsconfig.server.json",
    "dev": "cat .env.development.example > .env && vite",
    "dev:local": "read -p 'Enter DATABASE_URL: ' dburl && cat .env.local.example | sed \"s|replace_me|$dburl|g\" > .env && nodemon",
    "hooks:install": "git config core.hooksPath .githooks && chmod +x .githooks/*",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest run --config vitest.config.ts --watch",
    "watch:client": "react-router dev --config vite.config.ts --open",
    "watch:server": "tsx watch --tsconfig tsconfig.server.json ./src/server/index.ts"
  },
  "type": "module",
  "version": "0.0.0"
}
