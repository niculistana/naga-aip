{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext", // Matches modern Node.js ESM/CJS rules
    "moduleResolution": "NodeNext", // Required to match the 'module' setting
    "outDir": "./build/server",
    "rootDir": "./src/server",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src/server/**/*"],
  "exclude": ["node_modules", "dist", "build"]
}
