{
  "openapi": "3.0.0",
  "info": {
    "title": "Naga API",
    "version": "1.0.0",
    "description": "API for querying data by table."
  },
  "paths": {
    "/api/data/all/{table}": {
      "get": {
        "summary": "Get all rows from a table",
        "parameters": [
          {
            "name": "table",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The name of the table to query."
          },
          {
            "name": "fields",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Comma-separated list of fields to return."
          }
        ],
        "responses": {
          "200": {
            "description": "A list of rows.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "array",
                      "items": { "type": "object" }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request (missing or invalid fields).", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "500": { "description": "Internal server error.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/data/one/{table}/id/{id}": {
      "get": {
        "summary": "Get a single row from a table by ID",
        "parameters": [
          {
            "name": "table",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The name of the table to query."
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The ID of the row to retrieve."
          },
          {
            "name": "fields",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Comma-separated list of fields to return."
          }
        ],
        "responses": {
          "200": {
            "description": "The matching row.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": { "type": "array", "items": { "type": "object" } }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request (missing or invalid fields).", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "500": { "description": "Internal server error.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/data/one/{table}/name/{name}": {
      "get": {
        "summary": "Get a single row from a table by name",
        "parameters": [
          {
            "name": "table",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The name of the table to query."
          },
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The name value of the row to retrieve."
          },
          {
            "name": "fields",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Comma-separated list of fields to return."
          }
        ],
        "responses": {
          "200": {
            "description": "The matching row.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": { "type": "array", "items": { "type": "object" } }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request (missing or invalid fields/table).", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "500": { "description": "Internal server error.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/tables": {
      "get": {
        "summary": "Get all available table names",
        "responses": {
          "200": {
            "description": "A list of table names.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "string" },
                  "example": ["clusters", "agencies", "programs", "amounts"]
                }
              }
            }
          }
        }
      }
    },
    "/api/fields": {
      "get": {
        "summary": "Get all allowed field names",
        "responses": {
          "200": {
            "description": "A list of allowed field names.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "string" },
                  "example": ["id", "name", "description", "total"]
                }
              }
            }
          }
        }
      }
    },
    "/api/fields/{table}": {
      "get": {
        "summary": "Get all allowed field names for a table",
        "parameters": [
          {
            "name": "table",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The table name to fetch allowed fields for."
          }
        ],
        "responses": {
          "200": {
            "description": "A list of allowed field names for the given table.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          },
          "400": { "description": "Bad request (invalid table).", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/sectors": {
      "get": {
        "summary": "Get all sectors",
        "responses": {
          "200": {
            "description": "A list of sectors.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "integer", "example": 1 },
                          "name": { "type": "string", "example": "Economic Sector" },
                          "year": { "type": "integer", "example": 2026 }
                        }
                      }
                    },
                    "message": { "type": "string", "example": "This API may be missing data which we are actively looking to add to, please file a request on Github to prioritize it." }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/programs": {
      "get": {
        "summary": "Get all programs (paginated)",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 1 },
            "description": "Page number (default: 1)."
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 20, "maximum": 100 },
            "description": "Number of items per page (default: 20, max: 100)."
          }
        ],
        "responses": {
          "200": {
            "description": "A paginated list of programs.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "program_id": { "type": "string", "example": "1" },
                          "name": { "type": "string", "example": "Purchase of Office Supplies" },
                          "implementation_status": { "type": "string", "example": "ACTIVE" }
                        }
                      }
                    },
                    "pagination": { "$ref": "#/components/schemas/Pagination" },
                    "message": { "type": "string", "example": "This API may be missing data which we are actively looking to add to, please file a request on Github to prioritize it." }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/units": {
      "get": {
        "summary": "Get all units (paginated)",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 1 },
            "description": "Page number (default: 1)."
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 20, "maximum": 100 },
            "description": "Number of items per page (default: 20, max: 100)."
          }
        ],
        "responses": {
          "200": {
            "description": "A paginated list of units.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "cluster_id": { "type": "string", "example": "1" },
                          "abbreviation": { "type": "string", "example": "CDRRMO" },
                          "year": { "type": "string", "example": "2026" }
                        }
                      }
                    },
                    "pagination": { "$ref": "#/components/schemas/Pagination" },
                    "message": { "type": "string", "example": "This API may be missing data which we are actively looking to add to, please file a request on Github to prioritize it." }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "page": { "type": "integer", "example": 1 },
          "page_size": { "type": "integer", "example": 20 },
          "total_items": { "type": "integer", "example": 1367 },
          "total_pages": { "type": "integer", "example": 69 },
          "has_next_page": { "type": "boolean", "example": true },
          "has_prev_page": { "type": "boolean", "example": false }
        }
      }
    }
  }
}